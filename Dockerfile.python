FROM python:3.13-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY pyproject.toml .
COPY wire_detection/ wire_detection/
RUN pip install --no-cache-dir .

EXPOSE 8000
CMD ["wire-tune"]
