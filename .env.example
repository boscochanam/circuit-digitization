# Copy to .env before: docker compose up --build
#
# Synthetic-only workflows (Tier 1 of docs/reproducing-the-paper.md) need none of these.
# The ground-truth wire and component labels are committed, so real-image evaluation needs
# only the CGHD source scans, which are not redistributed here (CC BY 4.0 source images).

# --- Required for real-image evaluation -------------------------------------
# CGHD source scans for the 134 verified images.
WIRE_GT_IMAGES=/path/to/cghd/images

# Root of the manually verified wire-label corpus, mounted by docker-compose for the
# tuner UI's "GT Labels" browser. Also used as a fallback for WIRE_GT_IMAGES, in which
# case the scans are expected under $GT_LABELS_PATH/images.
GT_LABELS_PATH=/path/to/ground_truth/labels_few_annot

# --- Optional: committed defaults are correct for a fresh clone --------------
# WIRE_GT_WIRE_LABELS=ground_truth/wire_labels        # 134 wire polyline files
# WIRE_COMPONENT_LABELS=ground_truth/component_labels # 134 component label files
#
# Roboflow HDC-Recognition export. A fallback source of component labels only;
# because component_labels/ is committed, most workflows never need it.
# WIRE_HDC_BASE=roboflow_test2
#
# Generated synthetic wire corpus. Defaults to <repo>/data/synthetic.
# Create it with: uv run wire-sdg --num-images 5 --output-dir data/synthetic
# SYNTHETIC_PATH=/path/to/synthetic
#
# Where generated artifacts are written. Defaults to <repo>/output.
# WIRE_OUTPUT_DIR=/path/to/output
#
# Scratch dir for the one-off CGHD quality-audit artifacts. Defaults to <repo>/data/workspace.
# WIRE_CGHD_WORKSPACE=/path/to/workspace

# --- Ports -------------------------------------------------------------------
# If port 8000 is already in use locally, change the host port:
# BACKEND_PORT=8008
# FRONTEND_PORT=4200
